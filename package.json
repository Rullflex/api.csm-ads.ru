{
  "name": "api.csm-ads.ru",
  "type": "module",
  "version": "1.0.0",
  "author": "",
  "license": "ISC",
  "keywords": [],
  "main": "app.ts",
  "directories": {
    "test": "test"
  },
  "scripts": {
    "start": "npm run build && fastify start dist/app.js",
    "build": "tsc && tsc-alias",
    "build:watch": "tsc && (concurrently \"tsc -w\" \"tsc-alias -w\")",
    "dev": "concurrently -k -p \"[{name}]\" -n \"TypeScript,App\" -c \"yellow.bold,cyan.bold\" \"pnpm:build:watch\" \"pnpm:dev:start\"",
    "dev:start": "nodemon --watch dist/app.js --delay 500 --ext js --exec \"pnpm exec fastify start dist/app.js\"",
    "test": "npm run build && tsc -p test/tsconfig.json && tsc-alias -p test/tsconfig.json && FASTIFY_AUTOLOAD_TYPESCRIPT=1 node --test --experimental-test-coverage --loader ts-node/esm test/**/*.ts",
    "lint": "eslint",
    "lint:fix": "eslint --fix"
  },
  "dependencies": {
    "@fastify/autoload": "^6.0.0",
    "@fastify/cors": "^11.1.0",
    "@fastify/env": "^5.0.3",
    "@fastify/formbody": "^8.0.2",
    "@fastify/jwt": "^10.0.0",
    "@fastify/multipart": "^9.0.3",
    "@fastify/sensible": "^6.0.0",
    "axios": "^1.11.0",
    "dotenv": "^17.2.1",
    "fastify": "^5.6.2",
    "fastify-cli": "^7.4.0",
    "fastify-plugin": "^5.0.0",
    "puppeteer": "^24.16.2",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "qs": "^6.14.0"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^5.2.1",
    "@fastify/type-provider-json-schema-to-ts": "^5.0.0",
    "@types/node": "^22.1.0",
    "@types/qs": "^6.14.0",
    "c8": "^10.1.2",
    "concurrently": "^9.0.0",
    "eslint": "^9.33.0",
    "fastify-tsconfig": "^3.0.0",
    "json-schema-to-ts": "^3.1.1",
    "nodemon": "^2.0.22",
    "ts-node": "^10.4.0",
    "tsc-alias": "^1.8.16",
    "tsc-watch": "^7.2.0",
    "typescript": "~5.8.2"
  }
}
